# ===== 复制本文件为 .env 并填入真实值 =====

# 数据库: 本地开发可用 SQLite; 生产/云端用 Supabase(Postgres)
DATABASE_URL=sqlite:///./rental.db
# Supabase 示例(从控制台 Project Settings → Database → Connection string 取, 推荐 Pooler 连接串):
# DATABASE_URL=postgresql+psycopg://postgres.xxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# 云端首次部署: 库为空时自动灌入演示目录(本地一般留 false)
AUTO_SEED=false
# 旧手机号直登兼容入口，生产保持 false
ENABLE_PHONE_LOGIN=false
# 本地 http 开发保持 false；正式 HTTPS 部署设为 true
SESSION_COOKIE_SECURE=false

# 订单超时自动取消：未付款 1 小时；已收款但商家未确认档期 12 小时
UNPAID_ORDER_TTL_HOURS=1
MERCHANT_REVIEW_TTL_HOURS=12
# Vercel Cron 调用 /api/cron/sweep 时使用；生成: python3 -c "import secrets;print(secrets.token_urlsafe(32))"
CRON_SECRET=

# DeepSeek LLM (OpenAI 兼容协议)
# 获取: https://platform.deepseek.com/ -> API Keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 敏感字段加密密钥 (AES-256, 32 字节的 base64 / 任意长字符串，演示用)
ENCRYPTION_KEY=change-me-in-production-please-32b

# ===== Phase 2: 飞书同步 (暂时留空，启用时再填) =====
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_ORDER_TABLE_ID=
