# ===== 生产环境变量模板 (v2.2) =====
# 复制到服务器上的 /etc/rental/.env (或部署目录), 填入真实值, 千万不要提交进 Git。

# 数据库: 推荐 Supabase(托管 Postgres); 从控制台取 Pooler 连接串(含 sslmode=require)
DATABASE_URL=postgresql+psycopg://postgres.xxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
# 或自管 Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/rental
# 或 SQLite 放持久目录(简单场景):
# DATABASE_URL=sqlite:////var/lib/rental/rental.db

# 🔴 关系到「后台密码哈希」与「会话令牌签名」, 必须是强随机串, 一旦泄露需立即更换
# 生成: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ENCRYPTION_KEY=__CHANGE_ME_strong_random__
SESSION_COOKIE_SECURE=true
ENABLE_PHONE_LOGIN=false
UNPAID_ORDER_TTL_HOURS=1
MERCHANT_REVIEW_TTL_HOURS=12
# Vercel Cron 调用 /api/cron/sweep 时使用；必须是强随机串
CRON_SECRET=__CHANGE_ME_strong_random__

# DeepSeek LLM (OpenAI 兼容); 留空则降级关键词规则
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 飞书双向同步 (启用时填); 表里需含「快递公司」「物流单号」两列才会同步物流
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_ORDER_TABLE_ID=
