# ===== 生产环境变量模板 (v2.2) =====
# 复制到服务器上的 /etc/rental/.env (或部署目录), 填入真实值, 千万不要提交进 Git。

# 数据库: SQLite 放持久目录(注意目录要存在且应用可写); 量级上来后可换 PostgreSQL
DATABASE_URL=sqlite:////var/lib/rental/rental.db
# DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/rental

# 🔴 关系到「后台密码哈希」与「会话令牌签名」, 必须是强随机串, 一旦泄露需立即更换
# 生成: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ENCRYPTION_KEY=__CHANGE_ME_strong_random__

# DeepSeek LLM (OpenAI 兼容); 留空则降级关键词规则
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 飞书双向同步 (启用时填); 表里需含「快递公司」「物流单号」两列才会同步物流
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_ORDER_TABLE_ID=
