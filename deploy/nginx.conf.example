# Nginx 反向代理 (bozipaopao.cn)
# 目标:
#   https://bozipaopao.cn/        -> 客户前端
#   https://admin.bozipaopao.cn/  -> 商家后台
#
# 安装:
#   sudo cp deploy/nginx.conf.example /etc/nginx/conf.d/rental.conf
#   sudo nginx -t && sudo systemctl reload nginx
#
# 证书:
#   可分别签发 bozipaopao.cn / admin.bozipaopao.cn, 也可使用包含这两个域名的证书。

upstream rental_app {
    server 127.0.0.1:8000;
}

server {
    listen 80;
    server_name bozipaopao.cn www.bozipaopao.cn admin.bozipaopao.cn;

    # 证书签发完成后, 建议把 HTTP 全量跳转 HTTPS:
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name bozipaopao.cn www.bozipaopao.cn;

    ssl_certificate     /etc/nginx/ssl/bozipaopao.cn.pem;
    ssl_certificate_key /etc/nginx/ssl/bozipaopao.cn.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 10m;

    location = /admin {
        return 301 https://admin.bozipaopao.cn/;
    }

    location /admin/ {
        return 301 https://admin.bozipaopao.cn/;
    }

    location / {
        proxy_pass http://rental_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 443 ssl http2;
    server_name admin.bozipaopao.cn;

    ssl_certificate     /etc/nginx/ssl/admin.bozipaopao.cn.pem;
    ssl_certificate_key /etc/nginx/ssl/admin.bozipaopao.cn.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 10m;

    location / {
        proxy_pass http://rental_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
