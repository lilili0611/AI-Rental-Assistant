# Nginx 反向代理 (v2.2) —— 监听 80/443, 转发到本机 uvicorn(127.0.0.1:8000)
# 安装:
#   sudo cp deploy/nginx.conf.example /etc/nginx/conf.d/rental.conf
#   把 your-domain.com 改成你已备案的域名
#   sudo nginx -t && sudo systemctl reload nginx
# HTTPS 证书推荐用 acme.sh 或 certbot 自动签发后, 取消下面 443 段注释。

server {
    listen 80;
    server_name your-domain.com;

    # 证书签发完成后, 建议把 HTTP 全量跳转 HTTPS:
    # return 301 https://$host$request_uri;

    client_max_body_size 10m;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

